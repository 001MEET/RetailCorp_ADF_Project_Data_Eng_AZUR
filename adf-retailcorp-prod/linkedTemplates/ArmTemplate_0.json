{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-retailcorp-prod"
		},
		"ls_sql_dw_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sql_dw'"
		},
		"ls_blob_storage_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_blob_storage'",
			"defaultValue": "DefaultEndpointsProtocol=https;AccountName=stretailcorpdata;EndpointSuffix=core.windows.net;"
		},
		"ls_key_vault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-retailcorp-secrets.vault.azure.net/"
		},
		"ls_sql_dw_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "db-retailcorp.database.windows.net"
		},
		"ls_sql_dw_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-retailcorp-dw"
		},
		"ls_sql_dw_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "SQLAdmin"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/ls_key_vault')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureKeyVault",
				"typeProperties": {
					"baseUrl": "[parameters('ls_key_vault_properties_typeProperties_baseUrl')]"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ls_sql_dw')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('ls_sql_dw_properties_typeProperties_server')]",
					"database": "[parameters('ls_sql_dw_properties_typeProperties_database')]",
					"encrypt": "optional",
					"trustServerCertificate": true,
					"authenticationType": "SQL",
					"userName": "[parameters('ls_sql_dw_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('ls_sql_dw_password')]"
					}
				}
			},
			"dependsOn": []
		},
